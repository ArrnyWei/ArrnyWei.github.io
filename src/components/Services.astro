---
import SectionHeading from './SectionHeading.astro';
import { site } from '../data/site';

const icons = [
  // APP
  'M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2zm0 2v16h10V4H7zm5 14a1 1 0 100-2 1 1 0 000 2z',
  // Web / System
  'M3 5a2 2 0 012-2h14a2 2 0 012 2v11a2 2 0 01-2 2h-5l1 3h2a1 1 0 110 2H8a1 1 0 110-2h2l1-3H5a2 2 0 01-2-2V5zm2 0v11h14V5H5z',
  // Planning
  'M12 2a10 10 0 100 20 10 10 0 000-20zm0 2a8 8 0 110 16 8 8 0 010-16zm1 3h-2v6l5 3 1-1.73L13 11V7z',
  // Consulting
  'M4 4h16a1 1 0 011 1v11a1 1 0 01-1 1h-9l-5 4v-4H4a1 1 0 01-1-1V5a1 1 0 011-1zm1 2v9h3v2.382L10.618 15H19V6H5zm3 3h8v2H8V9zm0 3h5v2H8v-2z',
];
---

<section id="services" class="section bg-white">
  <div class="container-content">
    <SectionHeading
      eyebrow="Services"
      title="服務項目"
      description="網站／APP／系統開發三大主軸，一條龍完成從規劃、設計、開發到維運的完整旅程。"
    />

    <ul class="grid sm:grid-cols-2 gap-6">
      {site.services.map((s, i) => (
        <li class="group relative p-8 bg-white border border-ink-100 rounded-sm hover:border-primary-400 hover:shadow-xl transition-all">
          <div class="flex items-start gap-4 mb-4">
            <span class="shrink-0 w-12 h-12 rounded-sm bg-primary-100 text-primary-700 flex items-center justify-center group-hover:bg-primary-600 group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d={icons[i]}/></svg>
            </span>
            <div>
              <div class="text-xs font-mono text-ink-400">0{i + 1}</div>
              <h3 class="text-xl font-bold text-ink-900">{s.title}</h3>
            </div>
          </div>
          <p class="text-sm text-ink-600 leading-loose">{s.desc}</p>
          {s.highlights && (
            <ul class="mt-5 flex flex-wrap gap-2">
              {s.highlights.map((h) => (
                <li class="text-xs px-2 py-1 bg-ink-50 text-ink-600 rounded-sm border border-ink-100">
                  {h}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
