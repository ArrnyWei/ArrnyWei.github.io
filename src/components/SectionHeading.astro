---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  theme?: 'light' | 'dark';
}
const { eyebrow, title, description, align = 'center', theme = 'light' } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = theme === 'dark' ? 'text-white' : 'text-ink-900';
const descColor = theme === 'dark' ? 'text-ink-200' : 'text-ink-600';
---

<div class={`max-w-2xl ${alignClass} mb-12 md:mb-16`}>
  {eyebrow && (
    <div class="text-xs font-semibold tracking-[0.3em] uppercase text-primary-600 mb-3">
      {eyebrow}
    </div>
  )}
  <h2 class={`text-3xl md:text-4xl font-bold leading-tight ${titleColor}`}>
    {title}
  </h2>
  {description && (
    <p class={`mt-4 leading-relaxed ${descColor}`}>{description}</p>
  )}
</div>
