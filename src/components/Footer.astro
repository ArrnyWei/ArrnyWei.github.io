---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-100 bg-ink-50">
  <div class="container-content py-10 md:py-14 grid gap-8 md:grid-cols-3">
    <div>
      <div class="flex items-baseline gap-2">
        <span class="font-bold text-2xl text-primary-600 lowercase tracking-wider">origi</span>
        <span class="text-sm text-ink-500">{site.name}</span>
      </div>
      <p class="mt-3 text-sm text-ink-600 leading-relaxed">{site.description}</p>
    </div>

    <div class="text-sm text-ink-700 space-y-2">
      <div><span class="text-ink-400">Email　</span><a href={`mailto:${site.email}`} class="hover:text-primary-700">{site.email}</a></div>
      <div><span class="text-ink-400">電話　</span><a href={`tel:${site.tel.replace(/[^0-9+]/g, '')}`} class="hover:text-primary-700">{site.tel}</a></div>
      <div><span class="text-ink-400">地址　</span>{site.address}</div>
      {site.taxId && <div><span class="text-ink-400">統編　</span>{site.taxId}</div>}
      <div><span class="text-ink-400">營業　</span>{site.businessHours}</div>
    </div>

    <div class="text-sm">
      <div class="font-medium text-ink-900 mb-3">快速導覽</div>
      <ul class="space-y-1.5 text-ink-700">
        {site.nav.map((item) => (
          <li><a href={item.href} class="hover:text-primary-700">{item.label}</a></li>
        ))}
        <li><a href="/portfolio/" class="hover:text-primary-700">完整作品實績</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-ink-100">
    <div class="container-content py-4 text-xs text-ink-400 flex flex-wrap items-center justify-between gap-2">
      <div>© 1992–{year} {site.name}. All rights reserved.</div>
      <div>Powered by Astro &amp; Tailwind CSS</div>
    </div>
  </div>
</footer>
