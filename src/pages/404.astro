---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="找不到頁面" description="您嘗試造訪的頁面不存在。">
  <section class="section bg-white">
    <div class="container-content text-center py-20">
      <div class="text-accent text-sm tracking-[0.3em] uppercase mb-4">404</div>
      <h1 class="text-4xl md:text-5xl font-bold text-primary-900">找不到頁面</h1>
      <p class="mt-4 text-primary-600">您要造訪的頁面可能已被移除或網址有誤。</p>
      <a href="/" class="btn-primary mt-10 inline-flex">回到首頁</a>
    </div>
  </section>
</BaseLayout>
